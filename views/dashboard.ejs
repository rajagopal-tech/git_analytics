<!DOCTYPE html>
<html>
<head>
    <title>Analytics Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        .box-container { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        .box { padding: 20px; background: #f4f4f4; text-align: center; border-radius: 10px; cursor: pointer; transition: 0.3s; }
        .box:hover { background: #ddd; }
    </style>
</head>
<body>
    <h1>Analytics for: <%= repoUrl %></h1>
    <div class="box-container">
        <% categories.forEach(cat => { %>
            <a href="/category/<%= cat %>?repo=<%= repoUrl %>" style="text-decoration:none; color:black;">
                <div class="box">
                    <h3><%= cat.replace(/-/g, " ") %></h3>
                </div>
            </a>
        <% }) %>
    </div>
</body>
</html>
