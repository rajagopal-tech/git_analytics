<!DOCTYPE html>
<html>
<head>
  <title>Git Developer Analytics</title>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { background:#f7f7fb; }
    .category-card{ background:#fff;border-radius:12px;padding:16px;box-shadow:0 2px 10px rgba(0,0,0,.06);margin-bottom:20px; }
    .success{ color:green;font-weight:600;margin-bottom:10px; }
    .chart-wrap{ position:relative; height:280px; }
    .mh-120{ min-height:120px; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
    .truncate { max-width: 820px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display:inline-block; vertical-align:middle; }
  </style>
</head>
<body class="container py-4">
  <h1 class="mb-4 text-center">Git Developer Analytics</h1>

  <form method="POST" action="/analyze" class="mb-4">
    <div class="mb-3">
      <textarea name="repoUrls" class="form-control" rows="4" placeholder="Enter GitHub repo URLs (one per line), e.g.
https://github.com/user/repo1.git
https://github.com/org/repo2.git" required></textarea>
    </div>
    <button class="btn btn-primary">Analyze</button>
  </form>

  <% if (successMessage) { %>
    <p class="success"><%= successMessage %></p>
  <% } %>

  <% if (summaryData) { %>
    <div class="mb-5">
      <h2 class="mb-3">Summary of All Repositories</h2>
      <div class="row">
        <div class="col-md-3">
          <div class="category-card mh-120">
            <h6>Late Night Work</h6>
            <p class="mb-1"><strong><%= summaryData.timeDateActivity.lateNightPercentage %></strong></p>
            <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#sumLateNightModal">View table</button>
          </div>
        </div>

        <div class="col-md-3">
          <div class="category-card mh-120">
            <h6>Weekend Work</h6>
            <p class="mb-1"><strong><%= summaryData.timeDateActivity.weekendWork %></strong></p>
            <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#sumWeekendModal">View table</button>
          </div>
        </div>

        <div class="col-md-3">
          <div class="category-card mh-120">
            <h6>Most Active Day</h6>
            <p class="mb-0"><strong><%= summaryData.timeDateActivity.mostActiveDay %></strong></p>
          </div>
        </div>

        <div class="col-md-3">
          <div class="category-card mh-120">
            <h6>Burnout</h6>
            <p class="mb-0">Risk: <strong><%= summaryData.burnoutDetection.burnoutRisk %></strong></p>
            <p class="mb-0">Longest Streak: <strong><%= summaryData.burnoutDetection.longestStreak %></strong></p>
            <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#sumBurnoutModal">Idle gaps table</button>
          </div>
        </div>
      </div>

      <!-- Summary charts -->
      <div class="row">
        <div class="col-md-6">
          <div class="category-card">
            <h6>Commits by Day (All Repos)</h6>
            <div class="chart-wrap"><canvas id="sumDailyBar"></canvas></div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="category-card">
            <h6>Languages Used (All Repos)</h6>
            <div class="chart-wrap"><canvas id="sumLangPie"></canvas></div>
            <div class="small text-muted mt-2"><%= summaryData.languagesUsed.join(', ') %></div>
          </div>
        </div>
      </div>

      <!-- More summary charts -->
      <div class="row">
        <div class="col-md-4">
          <div class="category-card">
            <h6>Churn Rate (Avg %)</h6>
            <p class="mb-1"><strong><%= summaryData.churnRate %></strong></p>
            <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#sumChurnModal">View churn table</button>
            <div class="chart-wrap"><canvas id="sumChurnGauge"></canvas></div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="category-card">
            <h6>Large Commits (All Repos)</h6>
            <p class="mb-1">Total Count: <strong><%= summaryData.largeCommits.count %></strong></p>
            <p class="mb-2">Biggest Commit: <strong><%= summaryData.largeCommits.biggestCommitSize %></strong></p>
            <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#sumLargeModal">View table</button>
            <div class="chart-wrap"><canvas id="sumLargeByYear"></canvas></div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="category-card">
            <h6>Idle Period (Max)</h6>
            <p class="mb-2">Longest Idle: <strong><%= summaryData.idlePeriods.longestIdle %></strong></p>
            <div class="chart-wrap"><canvas id="sumLateVsWeekend"></canvas></div>
          </div>
        </div>
      </div>

      <!-- Year-wise -->
      <div class="row">
        <div class="col-md-4">
          <div class="category-card">
            <h6>Late Night by Year (Avg %)</h6>
            <div class="chart-wrap"><canvas id="sumLateNightYear"></canvas></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h6>Weekend Work by Year (Avg %)</h6>
            <div class="chart-wrap"><canvas id="sumWeekendYear"></canvas></div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h6>Churn by Year (Avg %)</h6>
            <div class="chart-wrap"><canvas id="sumChurnYear"></canvas></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== Summary MODALS (tables) ===== -->
    <!-- Late Night -->
    <div class="modal fade" id="sumLateNightModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Late Night Commits (All Repos)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <% const _ln = (summaryData.timeDateActivity.lateNightDetails||[]).slice(0,200); %>
          <% if (_ln.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle">
                <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Message</th><th>Hash</th></tr></thead>
                <tbody>
                  <% _ln.forEach((d,i)=>{ %>
                    <tr>
                      <td><%= i+1 %></td>
                      <td class="mono"><%= d.author %></td>
                      <td class="mono"><%= d.timeIST %></td>
                      <td class="mono"><span class="truncate"><%= d.message %></span></td>
                      <td class="mono"><%= d.hash %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-muted">No late night commits found.</div>
          <% } %>
        </div>
      </div></div>
    </div>

    <!-- Weekend -->
    <div class="modal fade" id="sumWeekendModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Weekend Commits (All Repos)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <% const _wk = (summaryData.timeDateActivity.weekendDetails||[]).slice(0,200); %>
          <% if (_wk.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle">
                <thead><tr><th>#</th><th>Author</th><th>Day</th><th>Time (IST)</th><th>Message</th><th>Hash</th></tr></thead>
                <tbody>
                  <% _wk.forEach((d,i)=>{ %>
                    <tr>
                      <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                      <td class="mono"><%= d.day %></td><td class="mono"><%= d.timeIST %></td>
                      <td class="mono"><span class="truncate"><%= d.message %></span></td>
                      <td class="mono"><%= d.hash %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-muted">No weekend commits found.</div>
          <% } %>
        </div>
      </div></div>
    </div>

    <!-- Burnout / Idle -->
    <div class="modal fade" id="sumBurnoutModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Idle Gaps (All Repos)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <% const _idle = (summaryData.burnoutDetection.idlePeriodDetails||[]).slice(0,200); %>
          <% if (_idle.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle">
                <thead><tr><th>#</th><th>Resumed By</th><th>Gap (days)</th><th>From (IST)</th><th>To (IST)</th><th>Hash</th></tr></thead>
                <tbody>
                  <% _idle.forEach((i,idx)=>{ %>
                    <tr>
                      <td><%= idx+1 %></td>
                      <td class="mono"><%= i.resumedBy %></td>
                      <td class="mono"><%= i.gapDays %></td>
                      <td class="mono"><%= i.fromIST %></td>
                      <td class="mono"><%= i.toIST %></td>
                      <td class="mono"><%= i.resumedHash %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-muted">No long idle gaps found.</div>
          <% } %>
        </div>
      </div></div>
    </div>

    <!-- Churn -->
    <div class="modal fade" id="sumChurnModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Churn-like Commits (All Repos)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <% const _ch = (summaryData.churnDetails||[]).slice(0,200); %>
          <% if (_ch.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle">
                <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Message</th><th>Hash</th></tr></thead>
                <tbody>
                  <% _ch.forEach((d,i)=>{ %>
                    <tr>
                      <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                      <td class="mono"><%= d.timeIST %></td>
                      <td class="mono"><span class="truncate"><%= d.message %></span></td>
                      <td class="mono"><%= d.hash %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-muted">No churn-like commits found.</div>
          <% } %>
        </div>
      </div></div>
    </div>

    <!-- Large commits -->
    <div class="modal fade" id="sumLargeModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Large Commits (All Repos)</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <% const _lg = (summaryData.largeCommits.details||[]).slice(0,200); %>
          <% if (_lg.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-striped align-middle">
                <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Total Changes</th><th>Message</th><th>Hash</th></tr></thead>
                <tbody>
                  <% _lg.forEach((d,i)=>{ %>
                    <tr>
                      <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                      <td class="mono"><%= d.timeIST %></td>
                      <td class="mono"><%= d.totalChanges %></td>
                      <td class="mono"><span class="truncate"><%= d.message %></span></td>
                      <td class="mono"><%= d.hash %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-muted">No large commits found.</div>
          <% } %>
        </div>
      </div></div>
    </div>
  <% } %>

  <!-- Per-repo sections -->
  <% if (repoDataList) { repoDataList.forEach((repo, idx) => { %>
    <div class="mb-5">
      <h3 class="mb-3"><%= repo.url %></h3>

      <% if (repo.error) { %>
        <div class="alert alert-danger">Error: <%= repo.error %></div>
      <% } else { %>
        <div class="row">
          <div class="col-md-3">
            <div class="category-card">
              <h6>Late Night</h6>
              <p class="mb-1"><%= repo.data.timeDateActivity.lateNightPercentage %></p>
              <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#repo-late-<%= idx %>-modal">View table</button>
            </div>
          </div>

          <div class="col-md-3">
            <div class="category-card">
              <h6>Weekend Work</h6>
              <p class="mb-1"><%= repo.data.timeDateActivity.weekendWork %></p>
              <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#repo-weekend-<%= idx %>-modal">View table</button>
            </div>
          </div>

          <div class="col-md-3">
            <div class="category-card">
              <h6>Most Active Day</h6>
              <p class="mb-0"><%= repo.data.timeDateActivity.mostActiveDay %></p>
            </div>
          </div>

          <div class="col-md-3">
            <div class="category-card">
              <h6>Burnout</h6>
              <p class="mb-0">Risk: <%= repo.data.burnoutDetection.burnoutRisk %></p>
              <p class="mb-0">Streak: <%= repo.data.burnoutDetection.longestStreak %></p>
              <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#repo-burnout-<%= idx %>-modal">Idle gaps table</button>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="row mt-3">
          <div class="col-md-6">
            <div class="category-card">
              <h6>Commits by Day</h6>
              <div class="chart-wrap"><canvas id="daily-<%= idx %>"></canvas></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="category-card">
              <h6>Authors Share</h6>
              <div class="chart-wrap"><canvas id="authors-<%= idx %>"></canvas></div>
            </div>
          </div>
        </div>

        <div class="row mt-3">
          <div class="col-md-4">
            <div class="category-card">
              <h6>Languages</h6>
              <div class="chart-wrap"><canvas id="langs-<%= idx %>"></canvas></div>
              <div class="small text-muted mt-2"><%= repo.data.languagesUsed.join(', ') %></div>
              <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#repo-msgs-<%= idx %>-modal">Commit messages table</button>
            </div>
          </div>

          <div class="col-md-4">
            <div class="category-card">
              <h6>Late Night vs Weekend</h6>
              <div class="chart-wrap"><canvas id="lateWeekend-<%= idx %>"></canvas></div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="category-card">
              <h6>Large Commits</h6>
              <p class="mb-1">Count: <strong><%= repo.data.largeCommits.count %></strong></p>
              <p class="mb-2">Biggest: <strong><%= repo.data.largeCommits.biggestCommitSize %></strong></p>
              <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#repo-large-<%= idx %>-modal">View table</button>
              <!-- Add missing canvas to match JS below -->
              <div class="chart-wrap"><canvas id="largeByYear-<%= idx %>"></canvas></div>
            </div>
          </div>
        </div>

        <!-- Yearly and churn -->
        <div class="row mt-3">
          <div class="col-md-6">
            <div class="category-card">
              <h6>Churn by Year (%)</h6>
              <div class="chart-wrap"><canvas id="churnYear-<%= idx %>"></canvas></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="category-card">
              <h6>Commits by Year</h6>
              <div class="chart-wrap"><canvas id="commitsYear-<%= idx %>"></canvas></div>
            </div>
          </div>
        </div>

        <!-- ===== Per-repo MODALS (tables) ===== -->
        <!-- Late Night -->
        <div class="modal fade" id="repo-late-<%= idx %>-modal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Late Night — <%= repo.url %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <% const r_ln = (repo.data.timeDateActivity.lateNightDetails||[]); %>
              <% if (r_ln.length) { %>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle">
                    <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Message</th><th>Hash</th></tr></thead>
                    <tbody>
                      <% r_ln.forEach((d,i)=>{ %>
                        <tr>
                          <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                          <td class="mono"><%= d.timeIST %></td>
                          <td class="mono"><span class="truncate"><%= d.message %></span></td>
                          <td class="mono"><%= d.hash %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %><div class="text-muted">No late night commits.</div><% } %>
            </div>
          </div></div>
        </div>

        <!-- Weekend -->
        <div class="modal fade" id="repo-weekend-<%= idx %>-modal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Weekend — <%= repo.url %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <% const r_wk = (repo.data.timeDateActivity.weekendDetails||[]); %>
              <% if (r_wk.length) { %>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle">
                    <thead><tr><th>#</th><th>Author</th><th>Day</th><th>Time (IST)</th><th>Message</th><th>Hash</th></tr></thead>
                    <tbody>
                      <% r_wk.forEach((d,i)=>{ %>
                        <tr>
                          <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                          <td class="mono"><%= d.day %></td><td class="mono"><%= d.timeIST %></td>
                          <td class="mono"><span class="truncate"><%= d.message %></span></td>
                          <td class="mono"><%= d.hash %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %><div class="text-muted">No weekend commits.</div><% } %>
            </div>
          </div></div>
        </div>

        <!-- Burnout / Idle -->
        <div class="modal fade" id="repo-burnout-<%= idx %>-modal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Idle Gaps — <%= repo.url %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <% const r_idle = (repo.data.burnoutDetection.idlePeriodDetails||[]); %>
              <% if (r_idle.length) { %>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle">
                    <thead><tr><th>#</th><th>Resumed By</th><th>Gap (days)</th><th>From (IST)</th><th>To (IST)</th><th>Hash</th></tr></thead>
                    <tbody>
                      <% r_idle.forEach((iRow,i)=>{ %>
                        <tr>
                          <td><%= i+1 %></td>
                          <td class="mono"><%= iRow.resumedBy %></td>
                          <td class="mono"><%= iRow.gapDays %></td>
                          <td class="mono"><%= iRow.fromIST %></td>
                          <td class="mono"><%= iRow.toIST %></td>
                          <td class="mono"><%= iRow.resumedHash %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %><div class="text-muted">No long idle gaps.</div><% } %>
            </div>
          </div></div>
        </div>

        <!-- Large commits -->
        <div class="modal fade" id="repo-large-<%= idx %>-modal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Large Commits — <%= repo.url %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <% const r_lg = (repo.data.largeCommits.details||[]); %>
              <% if (r_lg.length) { %>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle">
                    <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Total Changes</th><th>Message</th><th>Hash</th></tr></thead>
                    <tbody>
                      <% r_lg.forEach((d,i)=>{ %>
                        <tr>
                          <td><%= i+1 %></td><td class="mono"><%= d.author %></td>
                          <td class="mono"><%= d.timeIST %></td>
                          <td class="mono"><%= d.totalChanges %></td>
                          <td class="mono"><span class="truncate"><%= d.message %></span></td>
                          <td class="mono"><%= d.hash %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %><div class="text-muted">No large commits (&gt;100 changes).</div><% } %>
            </div>
          </div></div>
        </div>

        <!-- Commit messages -->
        <div class="modal fade" id="repo-msgs-<%= idx %>-modal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Commit Messages — <%= repo.url %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
              <% const r_msgs = (repo.data.commitMessageStructure.commitMessageDetails||[]).slice(0,200); %>
              <% if (r_msgs.length) { %>
                <div class="table-responsive">
                  <table class="table table-sm table-striped align-middle">
                    <thead><tr><th>#</th><th>Author</th><th>Time (IST)</th><th>Conventional</th><th>Message</th><th>Hash</th></tr></thead>
                    <tbody>
                      <% r_msgs.forEach((m,i)=>{ %>
                        <tr>
                          <td><%= i+1 %></td><td class="mono"><%= m.author %></td>
                          <td class="mono"><%= m.timeIST %></td>
                          <td><%= m.isConventional ? '✅' : '⚠️' %></td>
                          <td class="mono"><span class="truncate"><%= m.message %></span></td>
                          <td class="mono"><%= m.hash %></td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %><div class="text-muted">No commit message details.</div><% } %>
            </div>
          </div></div>
        </div>

      <% } %>
    </div>
  <% }) } %>

  <!-- Bootstrap JS (needed for modals) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // ===== Summary charts =====
    <% if (summaryData) { %>
      const sumDaily = <%- JSON.stringify(summaryData.timeDateActivity.dailyActivity) %>;
      new Chart(document.getElementById('sumDailyBar'), {
        type: 'bar',
        data: { labels: Object.keys(sumDaily), datasets: [{ label: 'Commits', data: Object.values(sumDaily) }] },
        options: { responsive:true, maintainAspectRatio:false }
      });

      const sumLangs = <%- JSON.stringify(summaryData.languagesUsed) %>;
      new Chart(document.getElementById('sumLangPie'), {
        type: 'pie',
        data: { labels: sumLangs, datasets: [{ data: sumLangs.map(()=>1) }] },
        options: { responsive:true, maintainAspectRatio:false }
      });

      const sumChurnPct = parseFloat('<%= summaryData.churnRate %>');
      new Chart(document.getElementById('sumChurnGauge'), {
        type: 'doughnut',
        data: { labels: ['Churn %','Remaining'], datasets: [{ data: [sumChurnPct, Math.max(0,100 - sumChurnPct)] }] },
        options: { cutout:'70%', responsive:true, maintainAspectRatio:false }
      });

      const sumLargeYear = <%- JSON.stringify(summaryData.largeCommitsByYear || {}) %>;
      new Chart(document.getElementById('sumLargeByYear'), {
        type: 'bar',
        data: { labels: Object.keys(sumLargeYear), datasets:[{ label:'Large Commits', data:Object.values(sumLargeYear) }] },
        options: { responsive:true, maintainAspectRatio:false }
      });

      const sumLate = parseFloat('<%= summaryData.timeDateActivity.lateNightPercentage %>');
      const sumWeekend = parseFloat('<%= summaryData.timeDateActivity.weekendWork %>');
      new Chart(document.getElementById('sumLateVsWeekend'), {
        type: 'bar',
        data: { labels:['Late Night %','Weekend %'], datasets:[{ label:'Avg %', data:[sumLate, sumWeekend] }] },
        options: { responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 } } }
      });

      const sumLateYear = <%- JSON.stringify(summaryData.lateNightByYearPct || {}) %>;
      new Chart(document.getElementById('sumLateNightYear'), {
        type: 'line',
        data: { labels: Object.keys(sumLateYear), datasets:[{ label:'Late Night %', data:Object.values(sumLateYear).map(v=>parseFloat(String(v).replace('%',''))) }] },
        options: { responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 } } }
      });

      const sumWeekendYear = <%- JSON.stringify(summaryData.weekendByYearPct || {}) %>;
      new Chart(document.getElementById('sumWeekendYear'), {
        type: 'line',
        data: { labels: Object.keys(sumWeekendYear), datasets:[{ label:'Weekend %', data:Object.values(sumWeekendYear).map(v=>parseFloat(String(v).replace('%',''))) }] },
        options: { responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 } } }
      });

      const sumChurnYear = <%- JSON.stringify(summaryData.churnByYearPct || {}) %>;
      new Chart(document.getElementById('sumChurnYear'), {
        type: 'line',
        data: { labels: Object.keys(sumChurnYear), datasets:[{ label:'Churn %', data:Object.values(sumChurnYear).map(v=>parseFloat(String(v).replace('%',''))) }] },
        options: { responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 } } }
      });
    <% } %>

    // ===== Per-repo charts =====
    <% if (repoDataList) { repoDataList.forEach((repo, idx) => { if (!repo.error) { %>
      const dAct<%= idx %> = <%- JSON.stringify(repo.data.timeDateActivity.dailyActivity) %>;
      new Chart(document.getElementById('daily-<%= idx %>'), {
        type:'bar',
        data:{ labels:Object.keys(dAct<%= idx %>), datasets:[{ label:'Commits', data:Object.values(dAct<%= idx %>)}] },
        options:{ responsive:true, maintainAspectRatio:false }
      });

      const authorAct<%= idx %> = <%- JSON.stringify(repo.data.authorActivity || {}) %>;
      new Chart(document.getElementById('authors-<%= idx %>'), {
        type:'pie',
        data:{ labels:Object.keys(authorAct<%= idx %>), datasets:[{ data:Object.values(authorAct<%= idx %>)}] },
        options:{ responsive:true, maintainAspectRatio:false }
      });

      const langs<%= idx %> = <%- JSON.stringify(repo.data.languagesUsed || []) %>;
      new Chart(document.getElementById('langs-<%= idx %>'), {
        type:'pie',
        data:{ labels:langs<%= idx %>, datasets:[{ data: langs<%= idx %>.map(()=>1) }] },
        options:{ responsive:true, maintainAspectRatio:false }
      });

      const latePct<%= idx %> = parseFloat('<%= repo.data.timeDateActivity.lateNightPercentage %>');
      const weekPct<%= idx %> = parseFloat('<%= repo.data.timeDateActivity.weekendWork %>');
      new Chart(document.getElementById('lateWeekend-<%= idx %>'), {
        type:'bar',
        data:{ labels:['Late Night %','Weekend %'], datasets:[{ label:'% of commits', data:[latePct<%= idx %>, weekPct<%= idx %>] }] },
        options:{ responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 }}}
      });

      const churnYear<%= idx %> = <%- JSON.stringify(repo.data.churnByYearPct || {}) %>;
      new Chart(document.getElementById('churnYear-<%= idx %>'), {
        type:'bar',
        data:{ labels:Object.keys(churnYear<%= idx %>), datasets:[{ label:'Churn %', data:Object.values(churnYear<%= idx %>).map(v=>parseFloat(String(v).replace('%',''))) }] },
        options:{ responsive:true, maintainAspectRatio:false, scales:{ y:{ beginAtZero:true, max:100 } } }
      });

      const commitsYear<%= idx %> = <%- JSON.stringify(repo.data.yearlyCommits || {}) %>;
      new Chart(document.getElementById('commitsYear-<%= idx %>'), {
        type:'line',
        data:{ labels:Object.keys(commitsYear<%= idx %>), datasets:[{ label:'Commits', data:Object.values(commitsYear<%= idx %>) }] },
        options:{ responsive:true, maintainAspectRatio:false }
      });

      const largeYear<%= idx %> = <%- JSON.stringify(repo.data.largeCommitsByYear || {}) %>;
      new Chart(document.getElementById('largeByYear-<%= idx %>'), {
        type:'bar',
        data:{ labels:Object.keys(largeYear<%= idx %>), datasets:[{ label:'Large Commits', data:Object.values(largeYear<%= idx %>) }] },
        options:{ responsive:true, maintainAspectRatio:false }
      });
    <% } }) } %>
  </script>
</body>
</html>
