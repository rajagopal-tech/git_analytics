<!DOCTYPE html>
<html>
<head>
  <title>Git Analytics</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background-color: #f5f5f5; }
    .category-card {
      background: white;
      border-radius: 10px;
      padding: 15px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    .success { color: green; font-weight: bold; margin-bottom: 15px; }
  </style>
</head>
<body class="container py-4">

  <h1 class="mb-4 text-center">Git Developer Analytics</h1>

  <form method="POST" action="/analyze" class="mb-4">
    <div class="mb-3">
      <textarea name="repoUrls" placeholder="Enter Repository URLs (one per line)" 
                class="form-control" rows="4" required></textarea>
    </div>
    <button class="btn btn-primary">Analyze</button>
  </form>

  <% if (successMessage) { %>
    <p class="success"><%= successMessage %></p>
  <% } %>

  <% /* --- SUMMARY SECTION FOR ALL REPOS --- */ %>
  <% if (summaryData) { %>
    <div class="mb-5">
      <h2>Summary of All Repositories</h2>
      <div class="row">
        <div class="col-md-4">
          <div class="category-card">
            <h5>Time & Date Activity</h5>
            <p>Late Night Work: <%= summaryData.timeDateActivity.lateNightPercentage %></p>
            <p>Weekend Work: <%= summaryData.timeDateActivity.weekendWork %></p>
            <p>Most Active Day: <%= summaryData.timeDateActivity.mostActiveDay %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Burnout Detection</h5>
            <p>Burnout Risk: <%= summaryData.burnoutDetection.burnoutRisk %></p>
            <p>Longest Streak: <%= summaryData.burnoutDetection.longestStreak %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Churn Rate</h5>
            <p><%= summaryData.churnRate %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Idle Periods</h5>
            <p>Longest Idle: <%= summaryData.idlePeriods.longestIdle %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Commit Message Structure</h5>
            <p>Meaningful Messages: <%= summaryData.commitMessageStructure.meaningfulMessages %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Languages Used</h5>
            <p><%= summaryData.languagesUsed.join(', ') %></p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="category-card">
            <h5>Large Commits</h5>
            <p>Count: <%= summaryData.largeCommits.count %></p>
            <p>Biggest Commit: <%= summaryData.largeCommits.biggestCommitSize %></p>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <% /* --- INDIVIDUAL REPO RESULTS --- */ %>
  <% if (repoDataList) { %>
    <% repoDataList.forEach(repo => { %>
      <div class="mb-5">
        <h3><%= repo.url %></h3>
        <% if (repo.error) { %>
          <div class="alert alert-danger">Error: <%= repo.error %></div>
        <% } else { %>
          <div class="row">
            <div class="col-md-4">
              <div class="category-card">
                <h5>Time & Date Activity</h5>
                <p>Late Night Work: <%= repo.data.timeDateActivity.lateNightPercentage %></p>
                <p>Weekend Work: <%= repo.data.timeDateActivity.weekendWork %></p>
                <p>Most Active Day: <%= repo.data.timeDateActivity.mostActiveDay %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Burnout Detection</h5>
                <p>Burnout Risk: <%= repo.data.burnoutDetection.burnoutRisk %></p>
                <p>Longest Streak: <%= repo.data.burnoutDetection.longestStreak %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Churn Rate</h5>
                <p><%= repo.data.churnRate %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Idle Periods</h5>
                <p>Longest Idle: <%= repo.data.idlePeriods.longestIdle %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Commit Message Structure</h5>
                <p>Meaningful Messages: <%= repo.data.commitMessageStructure.meaningfulMessages %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Languages Used</h5>
                <p><%= repo.data.languagesUsed.join(', ') %></p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="category-card">
                <h5>Large Commits</h5>
                <p>Count: <%= repo.data.largeCommits.count %></p>
                <p>Biggest Commit: <%= repo.data.largeCommits.biggestCommitSize %></p>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% }) %>
  <% } %>

</body>
</html>
